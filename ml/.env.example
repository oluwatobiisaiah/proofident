PORT=8001
HOST=0.0.0.0
ENV=development
LOG_LEVEL=info
MODEL_DIR=src/data/models
REDIS_URL=redis://localhost:6379

# --- OCR configuration ---
# Option A (default): local Tesseract binary (baked into Docker image via apt)
#   TESSERACT_BINARY_PATH is only needed on Windows dev; in Docker it's in PATH.
TESSERACT_BINARY_PATH=tesseract
OCR_PROVIDER_PRIMARY=tesseract
OCR_PROVIDER_FALLBACK=none

# Option B: cloud OCR HTTP API (Google Vision proxy, AWS Textract, etc.)
#   Expects POST with file upload; response must be {"lines":[{"text","confidence","x","y"}]}
#   or {"text":"..."} for plain-text APIs.
# OCR_PROVIDER_PRIMARY=http
# OCR_PROVIDER_FALLBACK=tesseract   # falls back to local Tesseract on API failure
# OCR_HTTP_URL=https://your-ocr-api/extract
# OCR_HTTP_TOKEN=your-bearer-token
OCR_HTTP_URL=
OCR_HTTP_TOKEN=

# Set to a secret value to enable API key auth (Bearer token).
# Leave empty to disable auth (useful for local dev).
API_KEY=

# Comma-separated allowed CORS origins. Use * to allow all (dev only).
ALLOWED_ORIGINS=*
