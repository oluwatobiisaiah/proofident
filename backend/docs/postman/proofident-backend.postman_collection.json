    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/send-otp",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"08012345678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/send-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "send-otp"]
            },
            "description": "Requests an OTP. In dev mode the response includes `devOtp` — copy it directly into verify-otp."
          }
        },
        {
          "name": "POST /auth/verify-otp",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) pm.environment.set('accessToken', json.accessToken);",
                  "if (json.refreshToken) pm.environment.set('refreshToken', json.refreshToken);",
                  "if (json.user && json.user.id) pm.environment.set('userId', json.user.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"08012345678\",\n  \"otp\": \"PASTE_DEV_OTP_HERE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-otp"]
            },
            "description": "Verifies OTP and stores `accessToken`, `refreshToken`, and `userId` in the active environment."
          }
        },
        {
          "name": "POST /auth/bvn/initiate",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.sessionId) pm.environment.set('bvnSessionId', json.sessionId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bvn\": \"12345678901\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/bvn/initiate",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "bvn", "initiate"]
            },
            "description": "Starts BVN verification for the authenticated user."
          }
        },
        {
          "name": "POST /auth/verify-bvn",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{bvnSessionId}}\",\n  \"otp\": \"123456\",\n  \"method\": \"sms\",\n  \"dateOfBirth\": \"1995-01-31\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-bvn",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-bvn"]
