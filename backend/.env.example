NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/proofident
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-32-char-secret-at-minimum
JWT_ISSUER=proofident
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
ALLOWED_ORIGINS=http://localhost:3001
LOG_LEVEL=info
DB_POOL_MAX=10
SERVICE_NAME=proofident-backend
REQUEST_TIMEOUT_MS=15000
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=45
ALLOW_DEV_OTP_EXPOSURE=false
ENABLE_DEMO_ROUTES=false
ENCRYPTION_SECRET=replace-with-32-char-encryption-secret
SQUAD_SECRET_KEY=sk_test_placeholder
SQUAD_WEBHOOK_SECRET=whsec_placeholder
SQUAD_BASE_URL=https://sandbox-api-d.squadco.com
SQUAD_MERCHANT_ID=merchant-id
SQUAD_DEFAULT_BANK_CODE=058
TERMII_API_KEY=termii_placeholder
TERMII_SENDER_ID=PROOFID
TERMII_BASE_URL=https://api.ng.termii.com
SMS_PROVIDER=squad
SQUAD_SMS_SENDER_ID=PROOFID
MONO_SECRET_KEY=mono_placeholder
MONO_BASE_URL=https://api.withmono.com
# MONO_PUBLIC_KEY=mono_public_placeholder
MONO_REDIRECT_URL=http://localhost:3001/mono/callback
# MONO_WEBHOOK_SECRET=mono_webhook_placeholder
MONO_REALTIME_TRANSACTIONS=true
# Must match the ML service's API_KEY value (empty string disables auth on both sides)
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_TOKEN=ai-service-token
# true = workers run inside the server process (dev convenience, one terminal)
# false = run workers separately with: npm run dev:worker (recommended for production)
RUN_INLINE_QUEUE_WORKERS=true
FILE_UPLOAD_DIR=./uploads
CLOUDINARY_CLOUD_NAME=cloud_name_placeholder
CLOUDINARY_API_KEY=cloudinary_api_key_placeholder
CLOUDINARY_API_SECRET=cloudinary_api_secret_placeholder